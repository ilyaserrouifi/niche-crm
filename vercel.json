{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "page/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/backend/server.js"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/api/users/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/api/pipeline/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/api/tasks/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/api/finance/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/api/analytics/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/register.html",
      "dest": "/register.html"
    },
    {
      "src": "/login.html",
      "dest": "/login.html"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/profile.html",
      "dest": "/profile.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}